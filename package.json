{
  "name": "fretwise",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Guitar chord identifier with real-time fretboard, drop-2 inversions, scale overlays, and Karplus-Strong audio synthesis",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/assemble-site.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^6.4.2",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.2"
  }
}
